# Slack credentials (required)
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Server
PORT=3000

# Scheduling
POLL_INTERVAL_MINUTES=30
ENABLE_BULK_WG21=true
ENABLE_BULK_OPENSTD=true
ENABLE_ISO_PROBE=true

# Revision probing
PROBE_REVISION_DEPTH=3
PROBE_UNKNOWN_MAX_REV=2
PROBE_PREFIXES=["D","P"]
PROBE_EXTENSIONS=[".pdf",".html"]

# Tier A -- Watchlist
WATCHLIST_PAPERS=[]
WATCHLIST_AUTHORS=[]

# Tier B -- Frontier
FRONTIER_WINDOW_ABOVE=30
FRONTIER_WINDOW_BELOW=5
FRONTIER_EXPLICIT_RANGES=[]

# Tier C -- Recently active
TIER_C_LOOKBACK_MONTHS=18
TIER_C_PROBE_PREFIXES=["D"]
TIER_C_REVISION_DEPTH=1

# Adaptive backoff
BACKOFF_MISS_THRESHOLD=3
BACKOFF_MULTIPLIER=2
BACKOFF_MAX_SKIP=48
BACKOFF_RESET_ON_INDEX_HIT=true

# Tier C pruning
PRUNE_INACTIVE_MONTHS=24

# HTTP client
HTTP_CONCURRENCY=20
HTTP_TIMEOUT_SECONDS=10
HTTP_USE_HTTP2=true

# Notifications
NOTIFICATION_CHANNEL=
NOTIFY_ON_WATCHLIST_AUTHOR=true
NOTIFY_ON_WATCHLIST_PAPER=true
NOTIFY_ON_FRONTIER_HIT=true
NOTIFY_ON_TIER_C_HIT=true

# Storage
DATA_DIR=./data
CACHE_TTL_HOURS=1
